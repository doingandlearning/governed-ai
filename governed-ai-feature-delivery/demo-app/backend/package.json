{
  "name": "governed-ai-demo-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node -r ./scripts/load-env.cjs dist/main.nest.js",
    "dev": "node -r ./scripts/load-env.cjs --watch --require ts-node/register src/main.nest.ts",
    "dev:pretty": "node -r ./scripts/load-env.cjs --watch --require ts-node/register src/main.nest.ts | tsx src/ops/prettyTrace.ts",
    "dev:sample": "node -r ./scripts/load-env.cjs --require ts-node/register src/index.ts",
    "start:nest": "node -r ./scripts/load-env.cjs dist/main.nest.js",
    "dev:nest": "node -r ./scripts/load-env.cjs --require ts-node/register src/main.nest.ts",
    "eval:document-extraction": "node -r ./scripts/load-env.cjs --require ts-node/register src/evals/runDocumentExtractionEvals.ts",
    "version-bundle": "node -r ./scripts/load-env.cjs --require ts-node/register src/evals/generateVersionBundleManifest.ts",
    "release-gate": "node -r ./scripts/load-env.cjs --require ts-node/register src/evals/generateReleaseGateReport.ts",
    "ops:demo-safety": "node -r ./scripts/load-env.cjs --require ts-node/register src/ops/demoKillSwitchAndRollback.ts",
    "test": "vitest run",
    "test:dev": "vitest",
    "test:watch": "vitest --watch"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "dotenv": "^17.3.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@mastra/core": "^1.17.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}
